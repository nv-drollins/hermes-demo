# Hugging Face read token. Create one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_replace_me

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Numeric Telegram user ID from @userinfobot. Comma-separate multiple IDs.
TELEGRAM_ALLOWED_USERS=123456789

# Destination for proactive alerts. For a private DM, use the same numeric ID.
TELEGRAM_HOME_CHANNEL=123456789

# The tested image is pinned deliberately. Change only when validating an upgrade.
VLLM_IMAGE=vllm/vllm-openai@sha256:80bc9aaea8f35dae1ade94649893a0369ab261fb418ed7428ab3bb8a14173954
